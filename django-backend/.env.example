# Django
DEBUG=0
# Generate a long random value for production.
SECRET_KEY=replace-with-a-long-random-secret-key
# In production, set this to the actual allowed hosts for your application
ALLOWED_HOSTS=example.com,www.example.com

# Security
# For local dev with runserver, set these to 0.
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1
SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
USE_X_FORWARDED_PROTO=1

# CORS
# In production, set this to the actual origins of your frontend applications
CORS_ALLOW_ALL_ORIGINS=0
CORS_ALLOWED_ORIGINS=https://app.example.com

# Superuser
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=your-superadmin-password
SUPERADMIN_EMAIL=admin@example.com